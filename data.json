// expand to 300+
while(rawCompanies.length < 320){
  rawCompanies.push("Company"+rawCompanies.length);
}

// convert to structured
const companies = rawCompanies.map(name => {
  const domain = name.toLowerCase()
    .replace(/[^a-z0-9]/g,"") + ".com";

  return {
    name,
    domain,
    hq:"USA",
    url:`https://${domain}/careers`
  };
});

// SAFE OPEN
function openCompany(c){
  const url = c.url;

  // fallback search if broken
  const fallback = `https://www.google.com/search?q=${encodeURIComponent(c.name+" careers")}`;

  const win = window.open(url,"_blank","noopener");

  // fallback if blocked
  setTimeout(()=>{
    if(!win || win.closed){
      window.open(fallback,"_blank");
    }
  },1000);
}

// LOGO
function logo(domain){
  return `https://logo.clearbit.com/${domain}`;
}
